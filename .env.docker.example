# =============================================================================
# Docker Compose environment — copy to `.env` and edit.
#   cp .env.docker.example .env
# `.env` is git-ignored — keep real secrets out of version control.
# =============================================================================

# ----- Postgres -----
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=medusa
POSTGRES_PORT=5432
# SSL: false for the bundled Postgres; true for managed/cloud Postgres
DATABASE_SSL=false

# ----- Redis -----
REDIS_PORT=6379

# ----- Backend (REQUIRED — change these!) -----
JWT_SECRET=change-me-to-a-long-random-string
COOKIE_SECRET=change-me-to-a-long-random-string
BACKEND_PORT=9000
BACKEND_PUBLIC_URL=http://localhost:9000
STORE_URL=http://localhost:8000

# CORS (comma-separated origins)
STORE_CORS=http://localhost:8000
ADMIN_CORS=http://localhost:9000,http://localhost:7001
AUTH_CORS=http://localhost:8000,http://localhost:9000,http://localhost:7001

# Admin user created on first boot (init-backend seed)
MEDUSA_ADMIN_EMAIL=admin@example.com
MEDUSA_ADMIN_PASSWORD=supersecret

# ----- Storefront -----
STOREFRONT_PORT=8000
# Baked into the browser bundle AND used by the storefront container to reach the
# backend. Locally these differ (browser=localhost, container=service DNS); see
# docs/DOCKER.md "Networking". In production set this to your public API domain.
NEXT_PUBLIC_MEDUSA_BACKEND_URL=http://localhost:9000
NEXT_PUBLIC_BASE_URL=http://localhost:8000
NEXT_PUBLIC_DEFAULT_REGION=us
# Optional: pin the publishable key to skip the /key-exchange auto-fetch.
# Leave blank to let the storefront fetch it from the backend on first build.
NEXT_PUBLIC_MEDUSA_PUBLISHABLE_KEY=
# Set true to force a Next.js rebuild on next start (after changing NEXT_PUBLIC_*).
FORCE_REBUILD=false

# ----- Payments (optional — leave blank to disable a provider) -----
# NOTE: never commit real keys. Rotate any key that has been shared in plaintext.
STRIPE_API_KEY=
STRIPE_WEBHOOK_SECRET=
RINGGITPAY_APP_ID=
RINGGITPAY_REQUEST_KEY=
RINGGITPAY_RESPONSE_KEY=
RINGGITPAY_IS_SANDBOX=false
HITPAY_API_KEY=

# ----- Email (optional — pick Resend OR SendGrid) -----
RESEND_API_KEY=
RESEND_FROM_EMAIL=
SENDGRID_API_KEY=
SENDGRID_FROM=

# ----- MinIO (optional — only used with `--profile full`) -----
# To use MinIO for media, set MINIO_ENDPOINT to the reachable host (e.g. localhost:9100)
MINIO_ENDPOINT=
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=medusa-media
MINIO_PORT=9100
MINIO_CONSOLE_PORT=9101
NEXT_PUBLIC_MINIO_ENDPOINT=

# ----- MeiliSearch (optional — only used with `--profile full`) -----
MEILISEARCH_HOST=
MEILISEARCH_ADMIN_KEY=
MEILISEARCH_MASTER_KEY=masterKey123456
MEILISEARCH_PORT=7700
NEXT_PUBLIC_SEARCH_ENDPOINT=
NEXT_PUBLIC_SEARCH_API_KEY=
NEXT_PUBLIC_INDEX_NAME=products
